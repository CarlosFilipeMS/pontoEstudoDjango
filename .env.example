DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Catálogo (empresas)
CATALOG_DB_ENGINE=django.db.backends.sqlite3
CATALOG_DB_NAME=

# Tenants (mesmo engine em geral; NAME preenchido por empresa ou arquivo em ./tenants/)
TENANT_DB_ENGINE=django.db.backends.sqlite3
TENANT_DB_USER=
TENANT_DB_PASSWORD=
TENANT_DB_HOST=
TENANT_DB_PORT=

# Opcional: diretório dos SQLite por subdomínio
# TENANTS_DIR=

APP_TIMEZONE=America/Sao_Paulo
AUTO_CLOSE_OPEN_ENTRY_MINUTES=1440
